{
  "name": "webchain-mirror",
  "version": "2.0.0",
  "description": "WebChain Mirror Node with LevelDB and API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "api": "node src/api/server.js",
    "start:all": "concurrently \"npm start\" \"npm run api\"",
    "start:sync": "node src/index.js",
    "migrate": "node scripts/migrate-to-leveldb.js",
    "test": "node --test",
    "clean": "rm -rf ./data && echo 'Cleaned data directory'",
    "monitor": "node scripts/monitor.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "events": "^3.3.0",
    "express": "^4.22.1",
    "level": "^8.0.0",
    "node-fetch": "^3.3.2",
    "wrtc": "^0.4.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
